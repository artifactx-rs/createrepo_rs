#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export RUSTFLAGS = -C opt-level=3 -C lto=fat -C codegen-units=1

%:
	dh $@

override_dh_auto_build:
	cargo build --release

override_dh_auto_test:
	cargo test --release

override_dh_auto_install:
	install -D -m 0755 target/release/createrepo_rs \
		debian/createrepo-rs/usr/bin/createrepo_rs

override_dh_installchangelogs:
	# Upstream doesn't ship a changelog file yet
	dh_installchangelogs || true
